{
  "name": "clipster-web",
  "private": true,
  "scripts": {
    "build": "esbuild src/app.ts --bundle --outfile=app.js --format=iife --target=es2020 --minify",
    "build:dev": "esbuild src/app.ts --bundle --outfile=app.js --format=iife --target=es2020 --sourcemap",
    "watch": "esbuild src/app.ts --bundle --outfile=app.js --format=iife --target=es2020 --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
