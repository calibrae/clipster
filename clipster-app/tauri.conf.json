{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-web/release-2.2-b/nicegram.schema.json",
  "productName": "Clipster",
  "version": "0.1.0",
  "identifier": "com.clipster.desktop",
  "build": {
    "frontendDist": "../web/dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
"macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clipster",
        "label": "main",
        "width": 400,
        "height": 600,
        "minWidth": 320,
        "minHeight": 400,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self'"
    }
  }
}
