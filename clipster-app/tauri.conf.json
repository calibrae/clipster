{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-web/release-2.2-b/nicegram.schema.json",
  "productName": "Clipster",
  "version": "0.1.0",
  "identifier": "com.clipster.app",
  "build": {
    "frontendDist": "../web"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clipster",
        "width": 420,
        "height": 600,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https: http:; connect-src 'self' https: http:"
    }
  }
}
